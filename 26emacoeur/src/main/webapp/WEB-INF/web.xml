<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <listener>
        <listener-class>bts.sio.emacoeur.database.ConnexionBdd</listener-class>
    </listener>
    
    <servlet>
        <servlet-name>PompierServlet</servlet-name>
        <servlet-class>bts.sio.emacoeur.servlet.PompierServlet</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>CaserneServlet</servlet-name>
        <servlet-class>bts.sio.emacoeur.servlet.CaserneServlet</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>GradesServlet</servlet-name>
        <servlet-class>bts.sio.emacoeur.servlet.GradesServlet</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>EnginServlet</servlet-name>
        <servlet-class>bts.sio.emacoeur.servlet.EnginServlet</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>InterventionServlet</servlet-name>
        <servlet-class>bts.sio.emacoeur.servlet.InterventionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PompierServlet</servlet-name>
        <url-pattern>/PompierServlet/*</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>ProfessionServlet</servlet-name>
        <servlet-class>bts.sio.emacoeur.servlet.ProfessionServlet</servlet-class>
    </servlet>
    
    
    <servlet-mapping>
        <servlet-name>PompierServlet</servlet-name>
        <url-pattern>/PompierServlet/listerPompier</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PompierServlet</servlet-name>
        <url-pattern>/PompierServlet/consulterPompier</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PompierServlet</servlet-name>
        <url-pattern>/PompierServlet/ajouterPompier</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PompierServlet</servlet-name>
        <url-pattern>/PompierServlet/modifierPompier</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>InterventionServlet</servlet-name>
        <url-pattern>/InterventionServlet/listerIntervention</url-pattern>
    </servlet-mapping>
    
    
    <servlet-mapping>
        <servlet-name>CaserneServlet</servlet-name>
        <url-pattern>/CaserneServlet/listerCaserne</url-pattern>
    </servlet-mapping>
    
    
    <servlet-mapping>
        <servlet-name>GradesServlet</servlet-name>
        <url-pattern>/GradesServlet/listerGrades</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>GradesServlet</servlet-name>
        <url-pattern>/GradesServlet/consulterGrades</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>GradesServlet</servlet-name>
        <url-pattern>/GradesServlet/ajouterGrades</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
    <servlet-name>EnginServlet</servlet-name>
        <url-pattern>/EnginServlet/listerEngin</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>ProfessionServlet</servlet-name>
        <url-pattern>/ProfessionServlet/listerProfession</url-pattern>
    </servlet-mapping>

  <servlet-mapping>
        <servlet-name>CaserneServlet</servlet-name>
        <url-pattern>/CaserneServlet/consulterCaserne</url-pattern>
    </servlet-mapping>
    
     <servlet-mapping>
        <servlet-name>CaserneServlet</servlet-name>
        <url-pattern>/CaserneServlet/ajouterCaserne</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>

</web-app>
